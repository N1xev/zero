{
  "name": "zero",
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "module": "bin/zero.ts",
  "type": "module",
  "bin": {
    "zero": "bin/zero.ts"
  },
  "scripts": {
    "dev": "go run ./cmd/zero",
    "test": "bun test ./tests --timeout 15000",
    "test:go": "go test ./...",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "build:go": "bun run scripts/build.ts",
    "smoke:build": "bun run scripts/smoke-build.ts",
    "smoke:go": "bun run scripts/smoke-go.ts",
    "review:pr": "go run ./cmd/zero-pr-review",
    "package:release": "go run ./cmd/zero-release package",
    "verify:release": "go run ./cmd/zero-release verify",
    "perf:bench": "bun run scripts/perf-bench.ts",
    "perf:smoke": "bun run scripts/perf-bench.ts --output dist/perf/perf-bench.json"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
